bmax <- min(dt |>
filter(dist == "N") |>
group_by(I2, k, k_large) |>
summarise(
bmax = mean(bias.ivw.random)
) |>
pull(bmax))
# Skew normal effects
bmaxlsn <- max(dt |>
filter(dist == "LSN") |>
group_by(I2, k, k_large) |>
summarise(
bmax = mean(bias.held.a)
) |>
pull(bmax))
