geom_segment(aes(y = 0.5, yend = 0.5, x = 0, xend = median_q,
linetype = "Median estimate"),
color = clrs[2], size = 0.3) +
geom_segment(aes(x = median_q, xend = median_q, y = 0, yend = 0.5,
linetype = "Median estimate"),
color = clrs[2], size = 0.3) +
geom_segment(aes(y = 0.025, yend = 0.025, x = 0, xend = q025,
